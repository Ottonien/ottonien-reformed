{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": [
          "firstperson_lefthand",
          "thirdperson_lefthand"
        ],
        "model": {
          "type": "minecraft:range_dispatch",
          "property": "minecraft:count",
          "normalize": false,
          "entries": [
            {
              "threshold": 2,
              "model": {
                "type": "minecraft:model",
                "model": "ottonien:item/jagdpfeil_offhand"
              }
            }
          ],
          "fallback": {
            "type": "minecraft:model",
            "model": "ottonien:item/jagdpfeil_offhand_1"
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "ottonien:item/jagdpfeil"
    }
  }
}
